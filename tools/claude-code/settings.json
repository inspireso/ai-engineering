{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(npm run)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(ls)",
      "Bash(mkdir)",
      "Bash(cat)"
    ],
    "deny": [
      "Bash(rm -rf)",
      "Bash(DROP)",
      "Bash(git push --force)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [".claude/hooks/pre-tool-use.sh"]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [".claude/hooks/post-tool-use.sh"]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [".claude/hooks/user-prompt-submit.sh"]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_PLUGINS": "true"
  }
}