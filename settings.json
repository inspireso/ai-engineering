{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(npm run)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(ls)",
      "Bash(mkdir)",
      "Bash(cat)"
    ],
    "deny": [
      "Bash(rm -rf)",
      "Bash(DROP)",
      "Bash(git push --force)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_PLUGINS": "true"
  }
}
