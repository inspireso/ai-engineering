{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(find)",
      "Bash(grep)",
      "Bash(ls)",
      "Bash(mkdir)",
      "Bash(cat)",
      "Bash(curl *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git commit *)",
      "Bash(npm)",
      "Bash(mvn)",
      "Bash(./mvnw)"
    ],
    "ask": [
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(rm *)",
      "Bash(git push *)"
    ],
    "deny": []
  },
  "env": {
    "CLAUDE_CODE_ENABLE_PLUGINS": "true"
  }
}
